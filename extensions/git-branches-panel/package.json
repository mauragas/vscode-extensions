{
  "name": "git-branches-panel",
  "displayName": "Git Branches Panel",
  "description": "Tree view for local and remote Git branches, stashes, worktrees, and tags with grouping, sync state, and quick actions.",
  "version": "1.5.0",
  "publisher": "karolis-mauragas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mauragas/vscode-extensions",
    "directory": "extensions/git-branches-panel"
  },
  "bugs": {
    "url": "https://github.com/mauragas/vscode-extensions/issues"
  },
  "homepage": "https://github.com/mauragas/vscode-extensions/tree/main/extensions/git-branches-panel#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "branches",
    "source control",
    "tree view",
    "sync",
    "merge"
  ],
  "icon": "resources/icon.png",
  "files": [
    "out",
    "resources",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "git-branches-container",
          "title": "Git Branches",
          "icon": "resources/branch.svg"
        }
      ]
    },
    "views": {
      "git-branches-container": [
        {
          "id": "gitBranchesPanel",
          "name": "Branches & Tags",
          "icon": "resources/branch.svg"
        }
      ],
      "scm": [
        {
          "id": "gitBranchesSCM",
          "name": "Branches",
          "icon": "resources/branch.svg",
          "when": "gitOpenRepositoryCount != 0"
        }
      ]
    },
    "commands": [
      {
        "command": "gitBranchesPanel.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "gitBranchesPanel.openSettings",
        "title": "Open Extension Settings",
        "icon": "$(gear)"
      },
      {
        "command": "gitBranchesPanel.fetchAll",
        "title": "Fetch All",
        "icon": "$(cloud-download)"
      },
      {
        "command": "gitBranchesPanel.fetchAllPrune",
        "title": "Fetch All (Prune)",
        "icon": "$(cloud-download)"
      },
      {
        "command": "gitBranchesPanel.showAdvancedActions",
        "title": "More Actions",
        "icon": "$(ellipsis)"
      },
      {
        "command": "gitBranchesPanel.stashSilently",
        "title": "Stash Silently",
        "icon": "$(archive)"
      },
      {
        "command": "gitBranchesPanel.syncCurrentBranch",
        "title": "Sync Current Branch",
        "icon": "$(sync)"
      },
      {
        "command": "gitBranchesPanel.publishCurrentBranch",
        "title": "Publish Current Branch",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "gitBranchesPanel.checkout",
        "title": "Checkout Branch",
        "icon": "$(arrow-right)"
      },
      {
        "command": "gitBranchesPanel.showBranchActions",
        "title": "More Branch Actions...",
        "icon": "$(ellipsis)"
      },
      {
        "command": "gitBranchesPanel.checkoutTag",
        "title": "Checkout Tag",
        "icon": "$(arrow-right)"
      },
      {
        "command": "gitBranchesPanel.syncBranch",
        "title": "Sync Branch",
        "icon": "$(sync)"
      },
      {
        "command": "gitBranchesPanel.publishBranch",
        "title": "Publish Branch",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "gitBranchesPanel.deleteBranch",
        "title": "Delete Branch",
        "icon": "$(trash)"
      },
      {
        "command": "gitBranchesPanel.removeStaleRemoteTrackingRef",
        "title": "Remove Stale Tracking Ref",
        "icon": "$(trash)"
      },
      {
        "command": "gitBranchesPanel.newBranch",
        "title": "New Branch",
        "icon": "$(add)"
      },
      {
        "command": "gitBranchesPanel.newBranchFromSelected",
        "title": "New Branch from Selected Branch...",
        "icon": "$(add)"
      },
      {
        "command": "gitBranchesPanel.newBranchFromSelectedAndCheckout",
        "title": "New Branch from Selected Branch and Checkout...",
        "icon": "$(add)"
      },
      {
        "command": "gitBranchesPanel.renameBranch",
        "title": "Rename Branch",
        "icon": "$(edit)"
      },
      {
        "command": "gitBranchesPanel.createTag",
        "title": "Create Tag...",
        "icon": "$(tag)"
      },
      {
        "command": "gitBranchesPanel.copyBranchName",
        "title": "Copy Branch Name",
        "icon": "$(copy)"
      },
      {
        "command": "gitBranchesPanel.copyTagName",
        "title": "Copy Tag Name",
        "icon": "$(copy)"
      },
      {
        "command": "gitBranchesPanel.mergeIntoCurrent",
        "title": "Merge into Current Branch",
        "icon": "$(git-merge)"
      },
      {
        "command": "gitBranchesPanel.compareBranchWithCurrent",
        "title": "Compare with Current Branch",
        "icon": "$(diff-multiple)"
      },
      {
        "command": "gitBranchesPanel.deleteTag",
        "title": "Delete Tag",
        "icon": "$(trash)"
      },
      {
        "command": "gitBranchesPanel.pushAllTags",
        "title": "Push All Tags",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "gitBranchesPanel.applyStash",
        "title": "Apply Stash"
      },
      {
        "command": "gitBranchesPanel.popStash",
        "title": "Pop Stash"
      },
      {
        "command": "gitBranchesPanel.dropStash",
        "title": "Drop Stash",
        "icon": "$(trash)"
      },
      {
        "command": "gitBranchesPanel.dropAllStashes",
        "title": "Drop All Stashes",
        "icon": "$(trash)"
      },
      {
        "command": "gitBranchesPanel.openWorktree",
        "title": "Open Worktree",
        "icon": "$(folder-opened)"
      },
      {
        "command": "gitBranchesPanel.openWorktreeInNewWindow",
        "title": "Open Worktree in New Window"
      },
      {
        "command": "gitBranchesPanel.revealWorktree",
        "title": "Reveal Worktree in File Explorer"
      },
      {
        "command": "gitBranchesPanel.copyWorktreePath",
        "title": "Copy Worktree Path",
        "icon": "$(copy)"
      },
      {
        "command": "gitBranchesPanel.removeWorktree",
        "title": "Remove Worktree",
        "icon": "$(trash)"
      },
      {
        "command": "gitBranchesPanel.syncFolderBranches",
        "title": "Sync Descendant Tracked Branches",
        "icon": "$(sync)"
      },
      {
        "command": "gitBranchesPanel.pushFolderBranches",
        "title": "Push Descendant Branches",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "gitBranchesPanel.deleteFolderBranches",
        "title": "Delete Descendant Branches",
        "icon": "$(trash)"
      },
      {
        "command": "gitBranchesPanel.deleteRemoteFolderBranches",
        "title": "Delete Descendant Remote Branches",
        "icon": "$(trash)"
      },
      {
        "command": "gitBranchesPanel.deleteFolderTags",
        "title": "Delete Descendant Tags",
        "icon": "$(trash)"
      },
      {
        "command": "gitBranchesPanel.pruneMissingUpstreamBranches",
        "title": "Prune Local Branches with Missing Upstream",
        "icon": "$(trash)"
      },
      {
        "command": "gitBranchesPanel.cleanRepository",
        "title": "Clean Repository",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitBranchesPanel.newBranch",
          "when": "(view == gitBranchesPanel || view == gitBranchesSCM) && config.gitBranchesPanel.toolbar.showNewBranch",
          "group": "navigation@1"
        },
        {
          "command": "gitBranchesPanel.stashSilently",
          "when": "(view == gitBranchesPanel || view == gitBranchesSCM) && config.gitBranchesPanel.toolbar.showStashSilently",
          "group": "navigation@2"
        },
        {
          "command": "gitBranchesPanel.syncCurrentBranch",
          "when": "(view == gitBranchesPanel || view == gitBranchesSCM) && config.gitBranchesPanel.toolbar.showCurrentBranchAction && !gitBranchesPanel.currentBranchNeedsPublish",
          "group": "navigation@3"
        },
        {
          "command": "gitBranchesPanel.publishCurrentBranch",
          "when": "(view == gitBranchesPanel || view == gitBranchesSCM) && config.gitBranchesPanel.toolbar.showCurrentBranchAction && gitBranchesPanel.currentBranchNeedsPublish",
          "group": "navigation@3"
        },
        {
          "command": "gitBranchesPanel.fetchAll",
          "when": "(view == gitBranchesPanel || view == gitBranchesSCM) && config.gitBranchesPanel.toolbar.showFetchAll",
          "group": "navigation@4"
        },
        {
          "command": "gitBranchesPanel.fetchAllPrune",
          "when": "(view == gitBranchesPanel || view == gitBranchesSCM) && config.gitBranchesPanel.toolbar.showFetchAllPrune",
          "group": "navigation@5"
        },
        {
          "command": "gitBranchesPanel.refresh",
          "when": "(view == gitBranchesPanel || view == gitBranchesSCM) && config.gitBranchesPanel.toolbar.showRefresh",
          "group": "navigation@6"
        },
        {
          "command": "gitBranchesPanel.showAdvancedActions",
          "when": "(view == gitBranchesPanel || view == gitBranchesSCM) && config.gitBranchesPanel.toolbar.showAdvancedActions",
          "group": "navigation@7"
        },
        {
          "command": "gitBranchesPanel.openSettings",
          "when": "(view == gitBranchesPanel || view == gitBranchesSCM) && config.gitBranchesPanel.toolbar.showSettings",
          "group": "navigation@8"
        }
      ],
      "view/item/context": [
        {
          "command": "gitBranchesPanel.syncBranch",
          "when": "viewItem == branch || viewItem == currentBranch",
          "group": "inline@1"
        },
        {
          "command": "gitBranchesPanel.publishBranch",
          "when": "viewItem == publishableBranch || viewItem == publishableCurrentBranch",
          "group": "inline@1"
        },
        {
          "command": "gitBranchesPanel.syncBranch",
          "when": "viewItem == branch || viewItem == currentBranch",
          "group": "1_branch@1"
        },
        {
          "command": "gitBranchesPanel.publishBranch",
          "when": "viewItem == publishableBranch || viewItem == publishableCurrentBranch",
          "group": "1_branch@1"
        },
        {
          "command": "gitBranchesPanel.checkout",
          "when": "viewItem == branch || viewItem == currentBranch || viewItem == publishableBranch || viewItem == publishableCurrentBranch || viewItem == remoteBranch",
          "group": "1_branch@2"
        },
        {
          "command": "gitBranchesPanel.newBranchFromSelected",
          "when": "viewItem == branch || viewItem == currentBranch || viewItem == publishableBranch || viewItem == publishableCurrentBranch || viewItem == remoteBranch || viewItem == staleRemoteBranch",
          "group": "1_branch@2.1"
        },
        {
          "command": "gitBranchesPanel.newBranchFromSelectedAndCheckout",
          "when": "viewItem == branch || viewItem == currentBranch || viewItem == publishableBranch || viewItem == publishableCurrentBranch || viewItem == remoteBranch || viewItem == staleRemoteBranch",
          "group": "1_branch@2.2"
        },
        {
          "command": "gitBranchesPanel.renameBranch",
          "when": "viewItem == branch || viewItem == currentBranch || viewItem == publishableBranch || viewItem == publishableCurrentBranch",
          "group": "1_branch@3"
        },
        {
          "command": "gitBranchesPanel.createTag",
          "when": "viewItem == branch || viewItem == currentBranch || viewItem == publishableBranch || viewItem == publishableCurrentBranch",
          "group": "1_branch@4"
        },
        {
          "command": "gitBranchesPanel.copyBranchName",
          "when": "viewItem == branch || viewItem == currentBranch || viewItem == publishableBranch || viewItem == publishableCurrentBranch || viewItem == remoteBranch || viewItem == staleRemoteBranch",
          "group": "1_branch@5"
        },
        {
          "command": "gitBranchesPanel.compareBranchWithCurrent",
          "when": "viewItem == branch || viewItem == publishableBranch || viewItem == remoteBranch || viewItem == staleRemoteBranch",
          "group": "1_branch@6"
        },
        {
          "command": "gitBranchesPanel.mergeIntoCurrent",
          "when": "viewItem == branch || viewItem == publishableBranch || viewItem == remoteBranch || viewItem == staleRemoteBranch",
          "group": "1_branch@7"
        },
        {
          "command": "gitBranchesPanel.deleteBranch",
          "when": "viewItem == branch || viewItem == publishableBranch || viewItem == remoteBranch",
          "group": "2_delete@1"
        },
        {
          "command": "gitBranchesPanel.removeStaleRemoteTrackingRef",
          "when": "viewItem == staleRemoteBranch",
          "group": "2_delete@1"
        },
        {
          "command": "gitBranchesPanel.showBranchActions",
          "when": "viewItem == branch || viewItem == currentBranch || viewItem == publishableBranch || viewItem == publishableCurrentBranch || viewItem == remoteBranch || viewItem == staleRemoteBranch",
          "group": "3_more@1"
        },
        {
          "command": "gitBranchesPanel.checkoutTag",
          "when": "viewItem == tag",
          "group": "1_tag@1"
        },
        {
          "command": "gitBranchesPanel.copyTagName",
          "when": "viewItem == tag",
          "group": "1_tag@2"
        },
        {
          "command": "gitBranchesPanel.deleteTag",
          "when": "viewItem == tag",
          "group": "2_tag@1"
        },
        {
          "command": "gitBranchesPanel.applyStash",
          "when": "viewItem == stash",
          "group": "1_stash@1"
        },
        {
          "command": "gitBranchesPanel.popStash",
          "when": "viewItem == stash",
          "group": "1_stash@2"
        },
        {
          "command": "gitBranchesPanel.dropStash",
          "when": "viewItem == stash",
          "group": "2_stash@1"
        },
        {
          "command": "gitBranchesPanel.openWorktree",
          "when": "viewItem == worktree || viewItem == currentWorktree",
          "group": "1_worktree@1"
        },
        {
          "command": "gitBranchesPanel.openWorktreeInNewWindow",
          "when": "viewItem == worktree || viewItem == currentWorktree",
          "group": "1_worktree@2"
        },
        {
          "command": "gitBranchesPanel.revealWorktree",
          "when": "viewItem == worktree || viewItem == currentWorktree",
          "group": "1_worktree@3"
        },
        {
          "command": "gitBranchesPanel.copyWorktreePath",
          "when": "viewItem == worktree || viewItem == currentWorktree",
          "group": "1_worktree@4"
        },
        {
          "command": "gitBranchesPanel.removeWorktree",
          "when": "viewItem == worktree",
          "group": "2_worktree@1"
        },
        {
          "command": "gitBranchesPanel.syncFolderBranches",
          "when": "viewItem == local-folder",
          "group": "1_folder@1"
        },
        {
          "command": "gitBranchesPanel.pushFolderBranches",
          "when": "viewItem == local-folder",
          "group": "1_folder@2"
        },
        {
          "command": "gitBranchesPanel.deleteFolderBranches",
          "when": "viewItem == local-folder",
          "group": "2_folder@1"
        },
        {
          "command": "gitBranchesPanel.deleteRemoteFolderBranches",
          "when": "viewItem == remote-folder",
          "group": "2_folder@2"
        },
        {
          "command": "gitBranchesPanel.deleteFolderTags",
          "when": "viewItem == tag-folder",
          "group": "2_folder@3"
        },
        {
          "command": "gitBranchesPanel.syncFolderBranches",
          "when": "viewItem == localSection",
          "group": "1_local@1"
        },
        {
          "command": "gitBranchesPanel.pruneMissingUpstreamBranches",
          "when": "viewItem == localSection",
          "group": "1_local@2"
        },
        {
          "command": "gitBranchesPanel.fetchAll",
          "when": "viewItem == remoteSection",
          "group": "1_remote@1"
        },
        {
          "command": "gitBranchesPanel.fetchAllPrune",
          "when": "viewItem == remoteSection",
          "group": "1_remote@2"
        },
        {
          "command": "gitBranchesPanel.dropAllStashes",
          "when": "viewItem == stashSection",
          "group": "1_stash@1"
        },
        {
          "command": "gitBranchesPanel.pushAllTags",
          "when": "viewItem == tagsSection",
          "group": "1_tags@1"
        }
      ]
    },
    "configuration": {
      "title": "Git Branches Panel",
      "properties": {
        "gitBranchesPanel.groupByFolder": {
          "type": "boolean",
          "default": true,
          "description": "Group branches by folder prefix (for example, feature/my-branch goes into the feature folder)."
        },
        "gitBranchesPanel.normalizeNewBranchNames": {
          "type": "boolean",
          "default": false,
          "description": "Apply extra lowercase kebab-case normalization to new branch names after the extension first sanitizes them into valid Git branch names, stripping special characters other than `-` while preserving folder separators (`/`)."
        },
        "gitBranchesPanel.sortOrder": {
          "type": "string",
          "enum": [
            "alphabetical",
            "recent"
          ],
          "default": "alphabetical",
          "description": "Sort branches alphabetically or by most recently updated commit."
        },
        "gitBranchesPanel.showCurrentBranchInfo": {
          "type": "boolean",
          "default": true,
          "description": "Show the current branch summary above the branches tree views."
        },
        "gitBranchesPanel.showStatusBarBranchAction": {
          "type": "boolean",
          "default": true,
          "description": "Show the status bar branch action that syncs or publishes the current branch."
        },
        "gitBranchesPanel.toolbar.showNewBranch": {
          "type": "boolean",
          "default": true,
          "description": "Show the New Branch quick action in the view toolbar."
        },
        "gitBranchesPanel.toolbar.showStashSilently": {
          "type": "boolean",
          "default": true,
          "description": "Show the Stash Silently quick action in the view toolbar."
        },
        "gitBranchesPanel.toolbar.showCurrentBranchAction": {
          "type": "boolean",
          "default": true,
          "description": "Show the Sync Current Branch or Publish Current Branch quick action in the view toolbar."
        },
        "gitBranchesPanel.toolbar.showFetchAll": {
          "type": "boolean",
          "default": true,
          "description": "Show the Fetch All quick action in the view toolbar."
        },
        "gitBranchesPanel.toolbar.showFetchAllPrune": {
          "type": "boolean",
          "default": true,
          "description": "Show the Fetch All (Prune) quick action in the view toolbar."
        },
        "gitBranchesPanel.toolbar.showRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Show the Refresh quick action in the view toolbar."
        },
        "gitBranchesPanel.toolbar.showAdvancedActions": {
          "type": "boolean",
          "default": true,
          "description": "Show the More Actions quick action in the view toolbar."
        },
        "gitBranchesPanel.toolbar.showSettings": {
          "type": "boolean",
          "default": true,
          "description": "Show the Open Extension Settings quick action in the view toolbar."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm --prefix ../.. run build:git-branches-panel",
    "compile": "npm --prefix ../.. run build:git-branches-panel",
    "watch": "npm --prefix ../.. run watch:git-branches-panel",
    "lint": "npm --prefix ../.. run lint:git-branches-panel",
    "test": "npm --prefix ../.. run test:git-branches-panel",
    "test:coverage": "npm --prefix ../.. run test:coverage:git-branches-panel",
    "package": "npx -y -p node@20 -p @vscode/vsce vsce package"
  }
}
